# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=ChangeMe_PleaseGenerateA32CharSecret
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# Format described at https://www.doctrine-project.org/projects/doctrine-dbal/en/current/reference/configuration.html#connecting-using-a-url
# Default for local Laragon (root, no password) — override in .env.local
DATABASE_URL="mysql://root:@127.0.0.1:3306/ttm_app?serverVersion=mariadb-10.6.0&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> symfony/mailer ###
# In dev, set this to a Mailpit/Mailtrap DSN, or use null:// to discard mails
MAILER_DSN=null://null
MAILER_FROM=noreply@ttm-toulouse.fr
MAILER_FROM_NAME="Triathlon Toulouse Métropole"
###< symfony/mailer ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=ChangeMe_GenerateAStrongPassphrase
JWT_TTL=3600
###< lexik/jwt-authentication-bundle ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^(https?://(localhost|127\.0\.0\.1|.*\.test)(:[0-9]+)?|exp://.*|app://.*)$'
###< nelmio/cors-bundle ###

###> ttm/app ###
# Public URL of the API (used in magic link emails)
APP_PUBLIC_URL=http://ttm-app.test
# Mobile deep-link scheme (Expo) for magic links - tries mobile first, falls back to web
APP_MOBILE_SCHEME=ttm://
# Magic link token TTL in seconds
MAGIC_LINK_TTL=900
# Expo Push API access token (optional, leave empty for unauthenticated push)
EXPO_ACCESS_TOKEN=
###< ttm/app ###

###> symfony/messenger ###
# Use doctrine transport for shared hosting (no Redis available)
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###
