{# Custom form theme that ONLY overrides the rich-text widget.
   Blocks not defined here fall through to the next theme registered
   in DashboardController::configureCrud()->setFormThemes(...)
   (which is EasyAdmin's default form_theme.html.twig). #}

{% block ea_text_editor_widget %}
    {% set widget_id = 'ck-' ~ (id|default('content')) %}
    <textarea
        id="{{ widget_id }}"
        name="{{ full_name }}"
        {% if required %}required="required"{% endif %}
        class="form-control ttm-ck-editor"
        rows="{{ form.vars.ea_vars.field.customOptions.get('numOfRows')|default(10) }}"
    >{{- value -}}</textarea>

    <script>
    (function () {
        var targetId = {{ widget_id|json_encode|raw }};

        function CustomUploadAdapterPlugin(editor) {
            editor.plugins.get('FileRepository').createUploadAdapter = function (loader) {
                return {
                    upload: function () {
                        return loader.file.then(function (file) {
                            return new Promise(function (resolve, reject) {
                                var data = new FormData();
                                data.append('upload', file);
                                fetch('/admin/upload/inline', {
                                    method: 'POST',
                                    body: data,
                                    credentials: 'same-origin',
                                })
                                    .then(function (r) { return r.json().then(function (j) { return { ok: r.ok, body: j }; }); })
                                    .then(function (res) {
                                        if (!res.ok) {
                                            var msg = (res.body && res.body.error && res.body.error.message) || 'Upload échoué';
                                            return reject(msg);
                                        }
                                        if (!res.body.url) { return reject('Réponse upload invalide'); }
                                        resolve({ default: res.body.url });
                                    })
                                    .catch(function (err) { reject(String(err)); });
                            });
                        });
                    },
                    abort: function () {},
                };
            };
        }

        function init() {
            var el = document.getElementById(targetId);
            if (!el || el.dataset.ckInit) return;
            if (typeof ClassicEditor === 'undefined') {
                setTimeout(init, 80);
                return;
            }
            el.dataset.ckInit = '1';

            ClassicEditor
                .create(el, {
                    extraPlugins: [CustomUploadAdapterPlugin],
                    language: 'fr',
                    toolbar: {
                        items: [
                            'heading', '|',
                            'bold', 'italic', 'link', '|',
                            'bulletedList', 'numberedList', '|',
                            'imageUpload', 'blockQuote', 'insertTable', '|',
                            'undo', 'redo'
                        ],
                    },
                    heading: {
                        options: [
                            { model: 'paragraph', title: 'Paragraphe', class: 'ck-heading_paragraph' },
                            { model: 'heading2', view: 'h2', title: 'Titre 2', class: 'ck-heading_heading2' },
                            { model: 'heading3', view: 'h3', title: 'Titre 3', class: 'ck-heading_heading3' },
                        ],
                    },
                    image: {
                        toolbar: [
                            'imageStyle:inline',
                            'imageStyle:block',
                            'imageStyle:side',
                            '|',
                            'toggleImageCaption',
                            'imageTextAlternative',
                            '|',
                            'resizeImage',
                        ],
                        resizeUnit: '%',
                        resizeOptions: [
                            { name: 'resizeImage:original', value: null, label: 'Originale' },
                            { name: 'resizeImage:25', value: '25', label: '25 %' },
                            { name: 'resizeImage:50', value: '50', label: '50 %' },
                            { name: 'resizeImage:75', value: '75', label: '75 %' },
                        ],
                    },
                })
                .catch(function (err) { console.error('CKEditor init failed', err); });
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', init);
        } else {
            init();
        }
    })();
    </script>
{% endblock ea_text_editor_widget %}
