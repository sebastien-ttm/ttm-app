{# Custom form theme : overrides EasyAdmin's rich-text widget to use
   TinyMCE 7 (community) instead of Trix. TinyMCE has native image
   resize handles via the `image` plugin. #}

{% block ea_text_editor_widget %}
    {% set widget_id = 'tmce-' ~ (id|default('content')) %}
    {# No `required` HTML5 attribute : TinyMCE hides the underlying textarea
       and the browser then refuses to submit the form for a hidden invalid
       field, silently in some browsers. Server-side validation (NotBlank)
       handles emptiness with a proper error message after submit. #}
    <textarea
        id="{{ widget_id }}"
        name="{{ full_name }}"
        class="form-control ttm-rich-editor"
        rows="{{ form.vars.ea_vars.field.customOptions.get('numOfRows')|default(15) }}"
    >{{- value -}}</textarea>

    <script>
    (function () {
        var targetId = {{ widget_id|json_encode|raw }};

        function imageUploadHandler(blobInfo, progress) {
            return new Promise(function (resolve, reject) {
                var data = new FormData();
                data.append('file', blobInfo.blob(), blobInfo.filename());
                fetch('/admin/upload/inline', {
                    method: 'POST',
                    body: data,
                    credentials: 'same-origin',
                })
                    .then(function (r) { return r.json().then(function (j) { return { ok: r.ok, body: j }; }); })
                    .then(function (res) {
                        if (!res.ok) {
                            var msg = (res.body && res.body.error && res.body.error.message) || 'Upload échoué';
                            return reject({ message: msg, remove: true });
                        }
                        if (!res.body.url) { return reject({ message: 'Réponse upload invalide', remove: true }); }
                        resolve(res.body.url);
                    })
                    .catch(function (err) { reject({ message: String(err), remove: true }); });
            });
        }

        function init() {
            var el = document.getElementById(targetId);
            if (!el || el.dataset.tmceInit) return;
            if (typeof tinymce === 'undefined') {
                setTimeout(init, 80);
                return;
            }
            el.dataset.tmceInit = '1';

            tinymce.init({
                selector: '#' + targetId,
                license_key: 'gpl',
                language: 'fr_FR',
                language_url: 'https://cdn.jsdelivr.net/npm/tinymce-i18n@latest/langs7/fr_FR.js',
                height: 420,
                min_height: 320,
                menubar: false,
                branding: false,
                promotion: false,
                statusbar: true,
                resize: true,
                plugins: 'autoresize lists link image table code',
                toolbar:
                    'undo redo | blocks | bold italic underline | bullist numlist | ' +
                    'link image table | alignleft aligncenter alignright alignjustify | code',
                block_formats: 'Paragraphe=p; Titre 2=h2; Titre 3=h3; Citation=blockquote',
                image_caption: true,
                image_advtab: true,
                image_dimensions: true,
                image_title: false,
                automatic_uploads: true,
                images_upload_handler: imageUploadHandler,
                images_reuse_filename: true,
                content_style:
                    'body { font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif; ' +
                    'font-size: 15px; line-height: 1.55; padding: 12px; } ' +
                    'img { max-width: 100%; height: auto; }',
                setup: function (editor) {
                    // Sync content back to the textarea on every change AND right
                    // before the form is submitted, in case TinyMCE's own submit
                    // hook is bypassed by client-side validation handlers.
                    editor.on('change keyup undo redo', function () { editor.save(); });
                    editor.on('init', function () {
                        var form = editor.targetElm.form;
                        if (form && !form.dataset.tmceSubmitHook) {
                            form.dataset.tmceSubmitHook = '1';
                            form.addEventListener('submit', function () { editor.save(); }, true);
                        }
                    });
                },
            });
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', init);
        } else {
            init();
        }
    })();
    </script>
{% endblock ea_text_editor_widget %}
