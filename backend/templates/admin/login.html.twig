<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Connexion — TTM Admin</title>
    <style>
        * { box-sizing: border-box; }
        body { margin: 0; font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif; background: #1a1a1a; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
        .card { background: #fff; padding: 40px; border-radius: 12px; box-shadow: 0 8px 32px rgba(0,0,0,0.5); width: 100%; max-width: 400px; }
        .logo { display: block; margin: 0 auto 20px; max-width: 280px; height: auto; }
        h1 { text-align: center; color: #1a1a1a; margin: 0 0 30px; font-size: 18px; font-weight: 600; }
        label { display: block; margin: 14px 0 6px; font-weight: 600; color: #333; font-size: 14px; }
        input[type=email], input[type=password] { width: 100%; padding: 11px 14px; border: 1px solid #ddd; border-radius: 6px; font-size: 15px; }
        input:focus { outline: none; border-color: #D32F2F; box-shadow: 0 0 0 3px rgba(211, 47, 47, 0.15); }
        button { width: 100%; padding: 12px; margin-top: 20px; background: #D32F2F; color: #fff; border: none; border-radius: 6px; font-size: 15px; font-weight: 600; cursor: pointer; }
        button:hover { background: #B71C1C; }
        .error { background: #FEE; color: #C62828; padding: 10px 14px; border-radius: 6px; margin-bottom: 16px; font-size: 14px; }
        .footer { text-align: center; margin-top: 24px; font-size: 12px; color: #888; }
    </style>
</head>
<body>
    <div class="card">
        <img src="{{ asset('img/logo_text.svg') }}" alt="Triathlon Toulouse Métropole" class="logo">
        <h1>Espace administration</h1>

        {% if error %}
            <div class="error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        <form method="post" action="{{ path('admin_login') }}">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <label for="email">Adresse e-mail</label>
            <input type="email" id="email" name="email" value="{{ last_username }}" required autofocus>

            <label for="password">Mot de passe</label>
            <input type="password" id="password" name="password" required>

            <button type="submit">Se connecter</button>
        </form>

        <div class="footer">Réservé aux administrateurs et entraîneurs</div>
    </div>
</body>
</html>
