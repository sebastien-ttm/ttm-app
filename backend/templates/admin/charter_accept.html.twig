<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Acceptation de la charte — TTM</title>
    <style>
        * { box-sizing: border-box; }
        body { margin: 0; font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif; background: #1a1a1a; min-height: 100vh; padding: 20px; }
        .wrap { max-width: 800px; margin: 20px auto; background: #fff; border-radius: 12px; overflow: hidden; box-shadow: 0 8px 32px rgba(0,0,0,0.3); }
        header { background: #D32F2F; color: #fff; padding: 24px; }
        header h1 { margin: 0 0 6px; font-size: 22px; }
        header .version { font-size: 13px; opacity: 0.85; }
        .scrollable { max-height: 60vh; overflow-y: auto; padding: 24px; line-height: 1.6; color: #222; }
        .scrollable img { max-width: 100%; height: auto; }
        footer { padding: 18px 24px; background: #fafafa; border-top: 1px solid #eee; display: flex; justify-content: space-between; align-items: center; gap: 12px; flex-wrap: wrap; }
        .hint { color: #666; font-size: 13px; flex: 1 1 200px; }
        .actions { display: flex; gap: 10px; }
        button { font: inherit; cursor: pointer; padding: 12px 20px; border-radius: 6px; border: 1px solid transparent; font-weight: 600; }
        .accept { background: #D32F2F; color: #fff; }
        .accept:disabled { background: #ccc; cursor: not-allowed; }
        .decline { background: transparent; color: #666; border-color: #ccc; }
    </style>
</head>
<body>
    <div class="wrap">
        <header>
            <h1>{{ charter.title }}</h1>
            <div class="version">Version {{ charter.version }}</div>
        </header>

        <div class="scrollable" id="content">
            {{ charter.content|raw }}
        </div>

        <footer>
            <span class="hint" id="hint">Faites défiler le texte jusqu'en bas pour activer le bouton.</span>
            <div class="actions">
                <a href="{{ path('admin_logout') }}" class="decline" style="text-decoration:none; padding:12px 20px; display:inline-block;">Refuser et me déconnecter</a>
                <form method="post" style="margin:0;">
                    <input type="hidden" name="accepted" value="1">
                    <button type="submit" class="accept" id="accept-btn" disabled>J'accepte la charte</button>
                </form>
            </div>
        </footer>
    </div>

    <script>
        (function () {
            var content = document.getElementById('content');
            var btn = document.getElementById('accept-btn');
            var hint = document.getElementById('hint');

            function check() {
                if (content.scrollTop + content.clientHeight >= content.scrollHeight - 8) {
                    btn.disabled = false;
                    hint.textContent = 'Vous avez lu la charte.';
                    hint.style.color = '#2E7D32';
                }
            }

            content.addEventListener('scroll', check);
            // Re-check on resize : if content is shorter than container, no scroll
            // is needed and the button can be enabled immediately.
            window.addEventListener('resize', check);
            // Initial check : pas de scroll possible si contenu déjà tout visible
            if (content.scrollHeight <= content.clientHeight + 8) {
                check();
            }
        })();
    </script>
</body>
</html>
