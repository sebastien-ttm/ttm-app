# Single .htaccess qui sert à la fois :
#   - le backend Symfony (routes /admin et /api → index.php)
#   - le mobile Expo web (toute autre route → index.html, fallback SPA)
#
# Le mobile dist/ (assets/, _expo/, index.html, metadata.json) est uploadé
# à côté de index.php dans public/. Les chemins ne se chevauchent pas
# avec les routes Symfony.

DirectoryIndex index.html index.php

<IfModule mod_negotiation.c>
    Options -MultiViews
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Force HTTPS en prod
    RewriteCond %{HTTPS} !=on
    RewriteCond %{HTTP_HOST} !^localhost
    RewriteCond %{HTTP_HOST} !^127\.0\.0\.1
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Passthrough du header Authorization (Lexik JWT) — Apache l'enlève par défaut
    RewriteCond %{HTTP:Authorization} .+
    RewriteRule ^ - [E=HTTP_AUTHORIZATION:%0]

    # Bloque les requêtes vers /index.php direct (sécurité + URLs canoniques)
    RewriteCond %{ENV:REDIRECT_STATUS} =""
    RewriteRule ^index\.php(?:/(.*)|$) /$1 [R=301,L]

    # 1) Fichier physique existant (assets mobile, /uploads/, /bundles/, etc.)
    #    → servi tel quel par Apache
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # 2) Routes du backend Symfony → index.php
    RewriteRule ^(admin|api|_(wdt|profiler|error))(/|$) index.php [L]

    # 3) Tout le reste → mobile SPA (index.html)
    #    Expo Router gère la navigation côté client.
    RewriteRule ^ index.html [L]
</IfModule>

<IfModule !mod_rewrite.c>
    <IfModule mod_alias.c>
        RedirectMatch 307 ^/$ /index.html
    </IfModule>
</IfModule>

# Bloquer l'accès aux dotfiles
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript application/json image/svg+xml
</IfModule>

# Cache
<IfModule mod_expires.c>
    ExpiresActive On
    # Assets versionnés (Expo + Symfony bundles) — cache long
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    # index.html : pas de cache (sinon les MAJ ne se voient pas)
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>
