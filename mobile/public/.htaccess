# Single-Page App routing — toutes les URLs inconnues retournent index.html,
# laissant Expo Router gérer la navigation côté client.
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Servir les fichiers et dossiers existants tels quels
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Tout le reste -> index.html
    RewriteRule ^ index.html [L]
</IfModule>

# Cache long pour les assets versionnés (Expo ajoute des hash dans les noms)
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"

    # index.html : pas de cache (sinon les MAJ ne se voient pas)
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# Compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml application/manifest+json
</IfModule>

# Type MIME explicite pour le manifest PWA (certains Apache anciens
# renvoient text/plain par défaut, ce qui empêche Chrome d'installer
# l'app).
<IfModule mod_mime.c>
    AddType application/manifest+json .webmanifest
</IfModule>
